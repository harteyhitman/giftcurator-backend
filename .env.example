DATABASE_URL=postgresql://username:password@localhost:5432/gifting
JWT_SECRET=replace-with-a-secure-random-string

# After editing schema: npx prisma migrate dev (local) or npx prisma migrate deploy (CI/Render)

# Browser origins allowed (signup, etc.). Prod: your Vercel URL.
FRONTEND_URL=http://localhost:3000
# Optional: extra origins, comma-separated
# FRONTEND_URLS=https://giftcurator-app.vercel.app
# Set to false to block *.vercel.app preview deploys
# ALLOW_VERCEL_PREVIEWS=true

# Same OAuth web client ID as the Next.js app (required for Google sign-in)
GOOGLE_CLIENT_ID=


